# pnpm does not auto-link local workspace packages the way npm does unless a dependency uses
# the workspace: protocol. kira-api/kira-workers/kira-bot depend on @ceronix/kira-shared with a
# plain "*" range (matching how the source-of-truth vantage monorepo, which uses npm workspaces,
# resolves it). Keeping the version specifier identical in both places avoids a divergent
# package.json between this deploy mirror and vantage, this setting makes pnpm behave like npm
# for workspace-name matches instead.
link-workspace-packages=true
